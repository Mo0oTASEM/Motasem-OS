# Motasem OS — Required Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env file to git.
#
# Frontend (VITE_*) vars are consumed by Vite at build time.
# Backend vars are consumed by the Node.js server.
# Some vars appear in both places — both must be set.

# ──────────────────────────────────────────────
# Supabase (required — frontend)
# ──────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Backend API URL (frontend uses this to reach the server)
VITE_API_BASE_URL=http://localhost:4000

# ──────────────────────────────────────────────
# Server — General
# ──────────────────────────────────────────────
PORT=8080
NODE_ENV=development
APP_BASE_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# In production, set ALLOW_LOCAL_DEV_AUTH=false (defaults to false when NODE_ENV=production)
ALLOW_LOCAL_DEV_AUTH=true
LOCAL_DEV_USER_ID=your-dev-user-uuid

# ──────────────────────────────────────────────
# Supabase (required — backend)
# ──────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_KEY=your_service_role_jwt

# ──────────────────────────────────────────────
# AI — Gemini (fallback provider for text + embeddings)
# ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ──────────────────────────────────────────────
# AI — Hermes (primary provider; text generation only)
# ──────────────────────────────────────────────
HERMES_API_KEY=your_hermes_api_key
HERMES_BASE_URL=https://hermes.ai/v1
HERMES_MODEL=hermes-3-llama-3.1-405b

# ──────────────────────────────────────────────
# Google OAuth (Planner, Calendar, Sheets, Docs, Gmail)
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/planner/google-calendar/oauth/callback
GOOGLE_TOKEN_ENCRYPTION_KEY=generate_a_long_random_secret_at_least_32_chars
GOOGLE_CALENDAR_WEBHOOK_URL=
GOOGLE_CALENDAR_WEBHOOK_SECRET=

# ──────────────────────────────────────────────
# Google Sheets (CRM integration)
# ──────────────────────────────────────────────
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
PAST_GOOGLE_SHEETS_IDS=

# ──────────────────────────────────────────────
# Telegram bot channel
# ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret
TELEGRAM_ALLOWED_CHAT_IDS=123456,-789012

# ──────────────────────────────────────────────
# WhatsApp Meta Cloud API channel
# ──────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_WEBHOOK_SECRET=your_app_secret
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_ALLOWED_SENDERS=15551234567,15557654321


